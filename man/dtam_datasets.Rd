\name{dtam_datasets}
\alias{dtam_datasets}
\title{List DTAM datasets}
\usage{
dtam_datasets()
}
\value{
A data frame with object names, underlying data names, broad frequency, source,
and a short description.
}
\description{
Returns a compact catalogue of the datasets shipped with DTAM.
}
\examples{
dtam_datasets()
}
